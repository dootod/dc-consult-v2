<section class="home-process" id="processus" aria-label="Notre processus de travail">
    <div class="container">

        <div class="home-section-header">
            <div class="home-section-eyebrow">
                <span class="home-section-eyebrow__bar"></span>
                Comment ça se passe
            </div>
            <h2 class="home-section-title home-section-title--center">
                Notre processus en 4 étapes
            </h2>
        </div>

        <div class="home-process__steps">

            <div class="home-process__line" aria-hidden="true"></div>

            <div class="home-process__step">
                <div class="home-process__step-bubble">
                    <i class="fa-solid fa-comments"></i>
                </div>
                <div class="home-process__step-num" aria-hidden="true">01</div>
                <h3 class="home-process__step-title">Prise de contact</h3>
                <p class="home-process__step-desc">
                    Échangeons sur vos besoins, contraintes techniques et délais pour
                    cadrer ensemble le projet.
                </p>
            </div>

            <div class="home-process__step">
                <div class="home-process__step-bubble">
                    <i class="fa-solid fa-file-lines"></i>
                </div>
                <div class="home-process__step-num" aria-hidden="true">02</div>
                <h3 class="home-process__step-title">Étude &amp; devis</h3>
                <p class="home-process__step-desc">
                    Analyse technique du dossier et remise d'une offre détaillée
                    sous 48h ouvrées.
                </p>
            </div>

            <div class="home-process__step">
                <div class="home-process__step-bubble">
                    <i class="fa-solid fa-pencil-ruler"></i>
                </div>
                <div class="home-process__step-num" aria-hidden="true">03</div>
                <h3 class="home-process__step-title">Conception &amp; modélisation</h3>
                <p class="home-process__step-desc">
                    Réalisation des plans et de la maquette 3D Tekla avec points
                    de validation réguliers.
                </p>
            </div>

            <div class="home-process__step">
                <div class="home-process__step-bubble">
                    <i class="fa-solid fa-flag-checkered"></i>
                </div>
                <div class="home-process__step-num" aria-hidden="true">04</div>
                <h3 class="home-process__step-title">Livraison &amp; suivi</h3>
                <p class="home-process__step-desc">
                    Remise du dossier complet et disponibilité pour toute question
                    lors de la phase chantier.
                </p>
            </div>

        </div>
    </div>
</section>


