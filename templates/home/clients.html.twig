{# ════════════════════════════════════════════════════════════════
   BANDE DE CONFIANCE
   ════════════════════════════════════════════════════════════════ #}
<section class="cl-trust" aria-label="Pourquoi ils nous choisissent">
    <div class="cl-trust__bg" aria-hidden="true"></div>
    <div class="container cl-trust__inner">

        <div class="cl-trust__header">
            <div class="cl-eyebrow">
                <span class="cl-eyebrow__bar"></span>
                Pourquoi ils nous choisissent
            </div>
            <h2 class="cl-trust__title">
                Des structures métalliques<br>pensées pour les pros
            </h2>
        </div>

        <div class="cl-trust__pillars">

            <div class="cl-pillar">
                <div class="cl-pillar__num" aria-hidden="true">01</div>
                <div class="cl-pillar__icon"><i class="fa-solid fa-bolt-lightning"></i></div>
                <h3 class="cl-pillar__title">Réactivité</h3>
                <p class="cl-pillar__desc">
                    Réponse sous 48h, livrables dans les délais contractuels.
                    Nous savons que le planning d'un chantier ne souffre aucun retard.
                </p>
            </div>

            <div class="cl-pillar">
                <div class="cl-pillar__num" aria-hidden="true">02</div>
                <div class="cl-pillar__icon"><i class="fa-solid fa-cube"></i></div>
                <h3 class="cl-pillar__title">Expertise BIM</h3>
                <p class="cl-pillar__desc">
                    Maquettes Tekla Structures complètes, coordination parfaite
                    entre tous les corps de métier, zéro surprise sur chantier.
                </p>
            </div>

            <div class="cl-pillar">
                <div class="cl-pillar__num" aria-hidden="true">03</div>
                <div class="cl-pillar__icon"><i class="fa-solid fa-handshake-simple"></i></div>
                <h3 class="cl-pillar__title">Interlocuteur unique</h3>
                <p class="cl-pillar__desc">
                    Un seul référent technique de la conception à la réception,
                    qui connaît votre projet dans ses moindres détails.
                </p>
            </div>

        </div>

    </div>
</section>


{# ════════════════════════════════════════════════════════════════
   CTA FINAL
   ════════════════════════════════════════════════════════════════ #}
<section class="cl-cta" aria-label="Rejoindre nos clients">
