            <span class="cl-ticker__sep">◆</span>
            <span>SARL Pérouze</span>
            <span class="cl-ticker__sep">◆</span>
            <span>SAS Chauvet</span>
            <span class="cl-ticker__sep">◆</span>
            {# Répétition pour l'effet infini #}
