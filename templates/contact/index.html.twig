{% extends 'base.html.twig' %}

{% block title %}Nous contacter{% endblock %}

{% block stylesheets %}
    {# Leaflet CSS — OpenStreetMap, fonctionne en local et en prod sans clé API #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css">
    <link rel="stylesheet" href="{{ asset('styles/contact.css') }}">
{% endblock %}

{% block body %}

{# ════════════════════════════════════════════════════════════════
   HERO — même style que projets-hero
   ════════════════════════════════════════════════════════════════ #}
<section class="contact-hero" aria-label="En-tête contact">
    <div class="contact-hero__bg" aria-hidden="true"></div>
    <div class="contact-hero__content container">
        <span class="contact-hero__label">Écrivez-nous</span>
        <h1 class="contact-hero__title">Nous contacter</h1>
        <p class="contact-hero__subtitle">
            Notre équipe est disponible du lundi au vendredi pour répondre
            à toutes vos questions et étudier votre projet.
        </p>
        <div class="contact-hero__line" aria-hidden="true"></div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   INFOS + FORMULAIRE
   ════════════════════════════════════════════════════════════════ #}
<section class="contact-section">
    <div class="container">

        <div class="contact-cols-row">

            {# ── Colonne gauche : informations ──────────────────────── #}
            <div class="contact-col-info">
                <div class="contact-info-card">

                    {# Header bandeau bleu #}
                    <div class="contact-info-card__header">
                        <h2 class="contact-info-card__header-title">Nos coordonnées</h2>
                        <p class="contact-info-card__header-sub">
                            <i class="fa-solid fa-circle" style="color:rgba(255,255,255,0.5);font-size:0.5rem;"></i>
                            Disponible du lundi au vendredi
                        </p>
                    </div>

                    {# Blocs — flex:1 pour occuper toute la hauteur #}
                    <div class="contact-info-card__body">

                        {# Adresse #}
                        <div class="contact-info-block">
                            <div class="contact-info-block__icon">
                                <i class="fa-solid fa-location-dot"></i>
                            </div>
                            <div class="contact-info-block__content">
                                <p class="contact-info-block__label">Adresse</p>
                                <p class="contact-info-block__value">
                                    10 Allée des Champs Élysées<br>
                                    91080 Évry-Courcouronnes
                                </p>
                            </div>
                        </div>

                        {# Téléphone #}
                        <a href="tel:+33637194574" class="contact-info-block">
                            <div class="contact-info-block__icon">
                                <i class="fa-solid fa-phone"></i>
                            </div>
                            <div class="contact-info-block__content">
                                <p class="contact-info-block__label">Téléphone</p>
                                <p class="contact-info-block__value">06 37 19 45 74</p>
                            </div>
                        </a>

                        {# Email #}
                        <a href="mailto:dc.consult@orange.fr" class="contact-info-block">
                            <div class="contact-info-block__icon">
                                <i class="fa-solid fa-envelope"></i>
                            </div>
                            <div class="contact-info-block__content">
                                <p class="contact-info-block__label">Email</p>
                                <p class="contact-info-block__value">dc.consult@orange.fr</p>
                            </div>
                        </a>

                        {# Horaires — redesign avec dot coloré #}
                        <div class="contact-info-block">
                            <div class="contact-info-block__icon">
                                <i class="fa-solid fa-clock"></i>
                            </div>
                            <div class="contact-info-block__content">
                                <p class="contact-info-block__label">Horaires d'ouverture</p>
                                <div class="contact-horaires">
                                    <div class="contact-horaires__item">
                                        <span class="contact-horaires__dot contact-horaires__dot--open"></span>
                                        <span class="contact-horaires__days">Lun. – Ven.</span>
                                        <span class="contact-horaires__time">8h00 – 18h00</span>
                                    </div>
                                    <div class="contact-horaires__item">
                                        <span class="contact-horaires__dot contact-horaires__dot--closed"></span>
                                        <span class="contact-horaires__days">Sam. – Dim.</span>
                                        <span class="contact-horaires__time contact-horaires__time--closed">Fermé</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            {# ── Colonne droite : formulaire ────────────────────────── #}
            <div class="contact-col-form">
                <div class="contact-form-card">

                    <h2 class="contact-form-card__title">Envoyer un message</h2>
                    <p class="contact-form-card__subtitle">
                        Les champs marqués d'un <strong style="color:var(--color-danger)">*</strong> sont obligatoires.
                    </p>
                    <div class="contact-form-card__divider"></div>

                    {% for message in app.flashes('success') %}
                        <div class="contact-flash contact-flash--success" data-auto-dismiss role="alert">
                            <i class="fa-solid fa-circle-check"></i>
                            <span>{{ message }}</span>
                        </div>
                    {% endfor %}
                    {% for message in app.flashes('danger') %}
                        <div class="contact-flash contact-flash--danger" role="alert">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <span>{{ message }}</span>
                        </div>
                    {% endfor %}

                    {{ form_start(form, {attr: {id: 'contactForm', novalidate: 'novalidate', class: 'contact-form-body'}}) }}

                        <div class="row g-3">
                            <div class="col-12 col-sm-6">
                                <div class="contact-field">
                                    <i class="fa-solid fa-user contact-field__icon"></i>
                                    {{ form_widget(form.nom, {attr: {class: 'dc-form-control', placeholder: 'Nom *'}}) }}
                                    {% if form.nom.vars.errors|length > 0 %}
                                        <div class="contact-field-error"><i class="fa-solid fa-circle-exclamation"></i><span>{{ form_errors(form.nom) }}</span></div>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="col-12 col-sm-6">
                                <div class="contact-field">
                                    <i class="fa-solid fa-user contact-field__icon"></i>
                                    {{ form_widget(form.prenom, {attr: {class: 'dc-form-control', placeholder: 'Prénom *'}}) }}
                                    {% if form.prenom.vars.errors|length > 0 %}
                                        <div class="contact-field-error"><i class="fa-solid fa-circle-exclamation"></i><span>{{ form_errors(form.prenom) }}</span></div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-sm-6">
                                <div class="contact-field">
                                    <i class="fa-solid fa-envelope contact-field__icon"></i>
                                    {{ form_widget(form.email, {attr: {class: 'dc-form-control', placeholder: 'Email *'}}) }}
                                    {% if form.email.vars.errors|length > 0 %}
                                        <div class="contact-field-error"><i class="fa-solid fa-circle-exclamation"></i><span>{{ form_errors(form.email) }}</span></div>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="col-12 col-sm-6">
                                <div class="contact-field">
                                    <i class="fa-solid fa-phone contact-field__icon"></i>
                                    {{ form_widget(form.telephone, {attr: {class: 'dc-form-control', placeholder: 'Téléphone (optionnel)'}}) }}
                                    {% if form.telephone.vars.errors|length > 0 %}
                                        <div class="contact-field-error"><i class="fa-solid fa-circle-exclamation"></i><span>{{ form_errors(form.telephone) }}</span></div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="contact-field">
                            <i class="fa-solid fa-tag contact-field__icon"></i>
                            {{ form_widget(form.sujet, {attr: {class: 'dc-form-control', placeholder: 'Sujet *'}}) }}
                            {% if form.sujet.vars.errors|length > 0 %}
                                <div class="contact-field-error"><i class="fa-solid fa-circle-exclamation"></i><span>{{ form_errors(form.sujet) }}</span></div>
                            {% endif %}
                        </div>

                        <div class="contact-field contact-field--textarea">
                            <i class="fa-solid fa-comment-dots contact-field__icon"></i>
                            {{ form_widget(form.message, {attr: {class: 'dc-form-control', placeholder: 'Votre message *', id: 'contact_message', rows: 5}}) }}
                            <span class="contact-char-counter" id="contactCharCounter" aria-live="polite">0 / 3000</span>
                            {% if form.message.vars.errors|length > 0 %}
                                <div class="contact-field-error"><i class="fa-solid fa-circle-exclamation"></i><span>{{ form_errors(form.message) }}</span></div>
                            {% endif %}
                        </div>

                        <div class="mt-3">
                            <button type="submit" class="contact-submit-btn" id="contactSubmitBtn">
                                <div class="btn-spinner"></div>
                                <span class="btn-text-default d-flex align-items-center gap-2">
                                    <i class="fa-solid fa-paper-plane"></i>
                                    Envoyer le message
                                </span>
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>

        </div>

        {# ════════════════════════════════════════════════════════
           MAP OPENSTREETMAP — Leaflet, pleine largeur, sans clé API
           Fonctionne en local (http) et en production (https)
           ════════════════════════════════════════════════════════ #}
        <div class="contact-map-section">
            <div class="contact-map-header">
                <i class="fa-solid fa-location-dot"></i>
                <span>10 Allée des Champs Élysées — 91080 Évry-Courcouronnes</span>
            </div>
            <div class="contact-map-wrapper" aria-label="Carte — DC Consult Évry-Courcouronnes">
                <div id="contactMap"></div>
            </div>
        </div>

    </div>
</section>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {# Leaflet JS #}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script src="{{ asset('js/contact.js') }}"></script>
{% endblock %}
