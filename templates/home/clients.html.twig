{% extends 'base.html.twig' %}

{% block title %}Nos clients - DC Consult{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/clients.css') }}">
{% endblock %}

{% block body %}

{# ════════════════════════════════════════════════════════════════
   HERO
   ════════════════════════════════════════════════════════════════ #}
<section class="cl-hero" aria-label="Nos clients">
    <div class="cl-hero__bg" aria-hidden="true">
        <div class="cl-hero__grid"></div>
        <span class="cl-hero__orb cl-hero__orb--a"></span>
        <span class="cl-hero__orb cl-hero__orb--b"></span>
    </div>

    <div class="container cl-hero__inner">

        <div class="cl-hero__badge">
            <span class="cl-hero__badge-dot"></span>
            Ils nous font confiance
        </div>

        <h1 class="cl-hero__title">
            Nos&nbsp;<em>clients</em><br>
            <span class="cl-hero__title-line"></span>
            depuis&nbsp;2024
        </h1>

        <p class="cl-hero__desc">
            Des groupes nationaux aux PME locales, DC&nbsp;Consult accompagne
            les acteurs majeurs de la construction métallique en Île-de-France
            et partout en France.
        </p>

        <div class="cl-hero__counters" aria-label="Chiffres clés">
            <div class="cl-hero__counter">
                <span class="cl-hero__counter-val" data-target="10">0</span>
                <span class="cl-hero__counter-label">Clients actifs</span>
            </div>
            <div class="cl-hero__counter-sep" aria-hidden="true"></div>
            <div class="cl-hero__counter">
                <span class="cl-hero__counter-val" data-target="5">0</span>
                <span class="cl-hero__counter-label">Groupes nationaux</span>
            </div>
            <div class="cl-hero__counter-sep" aria-hidden="true"></div>
            <div class="cl-hero__counter">
                <span class="cl-hero__counter-val" data-target="100">0</span>
                <span class="cl-hero__counter-label js-pct">% Satisfaction</span>
            </div>
        </div>

    </div>

    {# Ruban défilant de noms clients #}
    <div class="cl-ticker" aria-hidden="true">
        <div class="cl-ticker__track">
            <span>Groupe Treuil</span>
            <span class="cl-ticker__sep">◆</span>
            <span>Cesam Construction</span>
            <span class="cl-ticker__sep">◆</span>
            <span>Groupe Legendre</span>
